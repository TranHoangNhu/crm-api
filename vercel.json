{
    "version": 2,
    "builds": [
        {
            "src": "src/serverless.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": "documentation/**"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/serverless.ts"
        }
    ]
}